;============== Smooth Target Bind =======================
[State 0, MapSet]
type = MapSet
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
