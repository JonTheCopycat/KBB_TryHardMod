triggerall = enemy,name = "kaby"
trigger1 = 1
hidebars = 1
text1 = "<p2>Hello Dharkblu<wait=30>"

[State 190, 1] ;Freeze animation until PreIntro is over
type = ChangeAnim
triggerall = enemy,teammode = single && teammode = single
triggerall = enemy,teammode = single && teammode = single
trigger1 = RoundState = 0
value = 190

[State 190, 2] ;Assert this until you want "round 1, fight" to begin
type = AssertSpecial
trigger1 = 1
flag = Intro

[State 190, 4] 
type = ChangeState
triggerall = Ailevel = 0
triggerall = TeamLeader = playerno
trigger1 = AnimTime = 0
value = 195

[State 190, 4] ;Change to stand state
type = ChangeState
trigger1 = Ailevel > 0
trigger2 = TeamLeader != playerno
triggerall= AnimTime = 0
value = 0

;---------------------------------------------------------------------------
; Stand
[Statedef 0]
type = S
physics = S
sprpriority = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElem = 14
value = S1,4
channel = 0

[State 0, 1] ; whatever bro
type = ChangeAnim
trigger1 = prevstateno = 5900 && map(BladeOn) = 1
value = 7
persistent = 0


[State 0, 1]
type = ChangeAnim
trigger1 = Anim != 0 && Anim != 5 && Anim != 7
trigger2 = Anim = 5 && AnimTime = 0 ;Turn anim over
value = ifelse(map(BladeOn)=1,7,0)

[State 0, 1]
type = ChangeAnim
trigger1 = Anim = 5 && map(BladeOn)=1
value = 8

[State 0, 2]
type = VelSet
trigger1 = Time = 0
y = 0

[State 0, 3] ;Stop moving if low velocity or 4 ticks pass
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
trigger2 = Time = 4
x = 0

[State 0, 4] 
type = ChangeState
trigger1 = pos y < 0
value = 50
ctrl = 0

[State 0, 4] ;Are you dead?
type = ChangeState
trigger1 = !alive
value = 5050
ctrl = 0

;---------------------------------------------------------------------------
; Stand to Crouch
[Statedef 10]
type    = C
physics = C
anim = 10 + ifelse(map(BladeOn) = 1,6,0) 

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = S10,0
volumescale = 100

[State 10, 1]
type = VelMul
trigger1 = Time = 0
x = .75

[State 10, 2] ;Stop moving if low velocity
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0

[State 10, 3]
type = ChangeState
trigger1 = AnimTime = 0
value = 11

;---------------------------------------------------------------------------
; Crouching
[Statedef 11]
type    = C
physics = C
anim = 11 + ifelse(map(BladeOn) = 1,6,0) + ifelse(map(HasSword) = 0,4,0)
sprpriority = 0

[State 10, 2] ;Stop moving if low velocity
type = VelSet
trigger1 = abs(vel x) < Const(movement.crouch.friction.threshold)
x = 0

[State 11, 1] ;Change from turning animation
type = ChangeAnim
trigger1 = Anim = 6 && AnimTime = 0
value = 11


;---------------------------------------------------------------------------
; Crouch to Stand
[Statedef 12]
type    = S
physics = S
anim = 12 + ifelse(map(BladeOn) = 1,4,0)

[State 12, 1]
type = ChangeState
trigger1 = AnimTime = 0
value = 0

;---------------------------------------------------------------------------
; Walk
[Statedef 20]
type    = S
physics = S
sprpriority = 0

[State 20, 1]
type = VelSet
trigger1 = command = "holdfwd"
x = const(velocity.walk.fwd.x) + map(EmotionLv)/10

[State 20, 2]
type = VelSet
trigger1 = command = "holdback"
x = const(velocity.walk.back.x) - map(EmotionLv)/10

[State 20, 3]
type = ChangeAnim
triggerall = vel x > 0
trigger1 = Anim != 20 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 20

[State 20, 4]
type = ChangeAnim
triggerall = vel x < 0
trigger1 = Anim != 21 && Anim != 5
trigger2 = Anim = 5 && AnimTime = 0
value = 21
;---------------------------------------------------------------------------
; Jump Land
[Statedef 52]
type    = S
physics = S
ctrl = 0
anim = ifelse(map(BladeOn)=1,48,47)
facep2 = 1

[State 52, NotHitBy] ; Gives the player one frame of invincibility to prevent getting reset
type = NotHitBy
value = SCA
triggerall = prevstateno = 5040 || prevstateno = 5035
trigger1 = time = 0
time = 1

[State 52, CtrlSet] ; Gives control to the player if they landed in a non-juggle hurt state (To avoid potential unavoidable throw or reset setups)
type = CtrlSet
trigger1 = prevstateno = 5040 || prevstateno = 5035 || prevstateno = 5210
value = 1

[State 52, 1]
type = VelSet
trigger1 = Time = 0
y = 0

[State 52, 2]
type = PosSet
trigger1 = Time = 0
y = 0

[State 52, Enable Blocking] ; Lets the player low block if they're holding down back, ignoring landing recovery
type = ChangeState
triggerall = inguarddist
trigger1 = command = "holddown"
trigger1 = command = "holdback"
value = 120

[State 52, 3]
type = CtrlSet
trigger1 = Time = 3 
trigger2 = prevstateno = 5040
value = 1

[State 52, 4]
type = VelSet
trigger1 = abs(vel x) < Const(movement.stand.friction.threshold)
x = 0

[State 0, PlaySnd]
type = PlaySnd
trigger1 = AnimElem = 1
value = S3,3
volumescale = 100

[State 52, 5]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1
;---------------------------------------------------------------------------
; Run forward
[Statedef 100]
type    = S
physics = S
anim = 100
sprpriority = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = F100,0
volumescale = 500

[State 100, 1]
type = VelSet
trigger1 = map(HasSword) = 1
x = const(velocity.run.fwd.x) + (map(EmotionLv)-1)/2.5

[State 100, 1]
type = VelSet
trigger1 = map(HasSword) = 0
x = const(velocity.run.fwd.x) + 1.7

[State 0, Explod]
type = Explod
trigger1 = AnimElem = 1
anim = F16000
ID = 16000
pos = -40,0
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,0
accel = 0,0
random = 0,0
removetime = -2
pausemovetime = 0
scale = 0.75,0.75
sprpriority = 2
ontop = 0
shadow = 0,0,0
ownpal = 1

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 100, 4]
type = ChangeState
triggerall = ailevel = 0
trigger1 = command != "holdfwd"
value = 0

[State 100, 4]
type = ChangeState
triggerall = ailevel < 0
trigger1 = Time > 20
trigger2 = p2dist x < 20
value = 0

;---------------------------------------------------------------------------
; Initialize (at the start of the round)
[Statedef 5900]
type = S

[State 5900, 1] ;Clear all int variables
type = VarRangeSet
trigger1 = roundsexisted = 0
value = 0

[State 5900, 2] ;Clear all float variables
type = VarRangeSet
trigger1 = roundsexisted = 0
fvalue = 0

[State 5900, 3] ;Change palette
type = RemapPal
trigger1 = 1
source = 1,1
dest = 1,palno

[State 0, sword]
type = MapSet
trigger1 = 1
map = "HasSword"
value = 1

[State 0, sword]
type = MapSet
trigger1 = roundno >= 2
map = "BladeOn"
value = 1



[State 5900, 4] ;Intro for round 1
type = ChangeState
trigger1 = roundno = 1
value = 190

[State 5900, 5] ;All other rounds
type = ChangeState
trigger1 = 1
value = 0

