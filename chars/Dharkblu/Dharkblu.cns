;Change here for Target X Position of the opponent

[State 0, MapSet]
type = MapSet
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
map = "targetY"
value = 25
;Change here for Target y Position of the opponent

[State 0, MapSet]
type = MapSet
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
map = "delta"
value = 10
;Change here to affect how fast opponents will snap to target position

;------ DO NOT TOUCH ------	
[State 0, MapSet]
type = MapSet
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
map = "distX"
value = (pos x + map(targetX) * facing) - enemy,pos x

[State 0, MapSet]
type = MapSet
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
map = "distY"
value = (pos y + map(targetY)) - enemy,pos y

[State 0, TargetBind]
type = TargetBind
triggerall = movehit
trigger1 = anim = 624
trigger2 = anim = 625
trigger2 = AnimElem = 1, >= 0 && AnimElem = 3, < -1
time = 1
id = -1
pos = ifelse(abs(map(distX)) < map(delta),  map(targetX), ((enemy,pos x + map(delta) * map(distX) / abs(map(distX))) - pos x) * facing),    ifelse(abs(map(distY)) < map(delta), map(targetY), ((enemy,pos y + map(delta) * map(distY) / abs(map(distY))) - pos y))
;----- NO TOUCH END ------
;============== Smooth Target Bind End =======================

