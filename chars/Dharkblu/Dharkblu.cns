;Wavedash
[Statedef 30]
type = C
movetype= I
physics = S
anim = 30
ctrl = 0
sprpriority = 1

[State 0, PlaySnd]
type = PlaySnd
trigger1 = time = 0
value = F65,0
volumescale = 500

[State 0, sword]
type = MapSet
trigger1 = 1
map = "BladeOn"
value = 0

[State 0, AfterImage]
type = AfterImage
triggerall = numhelper(51000) = 0
trigger1 = AnimElem = 1
paladd = 255,240,0
time = 10
trans = add

[State 0, PosSet]
type = PosSet
trigger1 = AnimElem = 1
y = 0

[State 0, NotHitBy]
type = NotHitBy
trigger1 = time = [2, 10]
value = A, NA
time = 1

[State 0, VelSet]
type = VelSet
trigger1 = time = 0
x = (const(velocity.run.fwd.x) + (map(EmotionLv)-1)/2.5) * 1.8 * 0.6
y = 0

[State 0, VelSet]
type = VelSet
trigger1 = time = [1, 3]
x = (const(velocity.run.fwd.x) + (map(EmotionLv)-1)/2.5) * 1.8 * 1.25

[State 0, VelSet]
type = VelAdd
trigger1 = time > 5
trigger1 = vel x > 1
x = -0.25

[State 0, Explod]
type = Explod
trigger1 = AnimElem = 1
anim = F16000
ID = 16000
pos = -40,0
postype = p1  ;p2,front,back,left,right
facing = 1
vfacing = 1
bindtime = 1
vel = 0,0
accel = 0,0
random = 0,0
removetime = -2
pausemovetime = 0
scale = 0.75,0.75
sprpriority = 2
ontop = 0
shadow = 0,0,0
ownpal = 0

[State 200, End]
type = ChangeState
trigger1 = command = "holdup"
value = 60
ctrl = 0

[State 200, End]
type = ChangeState
trigger1 = command = "FF"
value = 100
ctrl = 1

[State 200, End]
type = ChangeState
trigger1 = command = "holdback"
value = 11
ctrl = 1

; i was lazy so its a bit hardcoded. If the sword is in the "wavedash" state then Dharkblu just has to wait 10 frames before doing the sword version. Otherwise, he can do the sword version immediately if he's near it.
[State 200, End]
type = ChangeState
trigger1 = command = "a" 
value = cond((helper(880),stateno=930 && time>=10 || helper(880),stateno!= 930 && helper(880),rootdist x = [-90,90] && helper(880),rootdist y = [-70,70]),290,260)
ctrl = 0
;
[State 200, End]
type = ChangeState
trigger1 = command = "b" 
value = cond((helper(880),stateno=930 && time>=10 || helper(880),stateno!= 930 && helper(880),rootdist x = [-90,90] && helper(880),rootdist y = [-70,70]),390,360)
ctrl = 0
;
[State 200, End]
type = ChangeState
trigger1 = command = "c"  && power >= 500
value = cond((helper(880),stateno=930 && time>=10 && helper(880),stateno!=491 || helper(880),stateno!= 930 && helper(880),stateno!=491 && helper(880),rootdist x = [-90,90] && helper(880),rootdist y = [-70,70]),490,495)
ctrl = 0

[State 200, End]
type = ChangeState
trigger1 = AnimTime = 0
value = 0
ctrl = 1

